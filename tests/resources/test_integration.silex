{
    "uid": "test.integration.basic",
    "import": ["./common"],
    "pattern": ".*test_project.*",
    "root_path": "../integration/test_data",
    "segmenter": "silex.impl.segmenters.FilesystemSegmenter",
    "context_filters": [
        {"project.code": "test_project"}
    ],
    "paths": {
        "project": {
            "pattern": "test_project",
            "parse": {
                "expressions": ["$lower({value})->project"],
                "targets": {
                    "project.code": "value",
                    "context.project": "value"
                }
            },
            "format": "test_project",
            "paths": {
                "tree": {
                    "pattern": "(shots|assets)",
                    "parse": {
                        "expressions": ["$lower({value})->tree"],
                        "targets": {
                            "context.tree": "tree"
                        }
                    },
                    "format": "{context.tree}",
                    "paths": {
                        "sequence": {
                            "pattern": "seq[0-9]+",
                            "parse": {
                                "expressions": ["$lower({value})->sequence"],
                                "targets": {
                                    "context.sequence": "value"
                                }
                            },
                            "format": "{context.sequence}",
                            "endpoint": "sequence",
                            "paths": {
                                "shot": {
                                    "pattern": "shot[0-9]+",
                                    "parse": {
                                        "expressions": ["$lower({value})->shot"],
                                        "targets": {
                                            "context.shot": "value"
                                        }
                                    },
                                    "format": "{context.shot}",
                                    "endpoint": "shot",
                                    "paths": {
                                        "frame_file": {
                                            "pattern": "([a-zA-Z0-9_]+)\\.([0-9]+)\\.([a-zA-Z]+)",
                                            "parse": {
                                                "targets": {
                                                    "context.task": {
                                                        "group": 1
                                                    },
                                                    "frame": {
                                                        "group": 2,
                                                        "type": "int"
                                                    },
                                                    "file.ext": {
                                                        "group": 3
                                                    }
                                                }
                                            },
                                            "format": "{context.shot}_{context.task}.{frame:04d}.{file.ext}",
                                            "endpoint": "shot.frame"
                                        }
                                    }
                                }
                            }
                        },
                        "asset_type": {
                            "pattern": "(characters|props|environments)",
                            "parse": {
                                "expressions": ["$lower({value})->asset_type"],
                                "targets": {
                                    "context.asset_type": "asset_type"
                                }
                            },
                            "format": "{context.asset_type}",
                            "paths": {
                                "asset_name": {
                                    "pattern": "[a-zA-Z][a-zA-Z0-9_]*",
                                    "parse": {
                                        "expressions": ["$lower({value})->asset_name"],
                                        "targets": {
                                            "context.asset_name": "value"
                                        }
                                    },
                                    "format": "{context.asset_name}",
                                    "endpoint": "asset"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
