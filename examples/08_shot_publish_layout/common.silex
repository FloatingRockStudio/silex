{
    "templates": {
        "shot_segment": {
            "pattern": "([0-9]+)-([0-9]+)",
            "format": "{context.sequence}-{context.shot}",
            "parse": {
                "targets": {
                    "context.sequence": {"group": 1},
                    "context.shot": {"group": 2}
                }
            }
        }
    }
}